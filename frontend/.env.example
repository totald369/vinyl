NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# GA4 측정 ID (미설정 시 빌드 시 기본 G-80ZYJJ27G5 사용, 콘솔에 경고). 빈 값이면 GA 스크립트 비활성화
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# SPA 라우트 전환 page_view만 끄려면 0 또는 false (최초 page_view는 GoogleAnalyticsScripts만)
NEXT_PUBLIC_GA_ROUTE_TRACKER=
# GA 디버그 로그(프로덕션 빌드에서만 의미 있음). 확인 후 비우기 권장 — 1 또는 true
NEXT_PUBLIC_GA_DEBUG=
NEXT_PUBLIC_KAKAO_MAP_APP_KEY=
# 공공데이터 「데이터기준일자」 (JSON 행에 없을 때 전체 매장에 동일 표시). 예: 2024-12-31 또는 20241231
NEXT_PUBLIC_STORE_DATA_REFERENCE_DATE=
